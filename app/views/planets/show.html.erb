<%= link_to "Return to Planetary Registry", planets_path, class: "btn-back" %>

<div class="page-header">
  <h1 class="page-title"><%= @planet.name %></h1>
</div>

<div class="row g-3">
  <div class="col-md-6">
    <div class="detail-panel">
      <div class="panel-title">Planetary Data</div>
      <% [
        ["Climate",        @planet.climate],
        ["Terrain",        @planet.terrain],
        ["Population",     @planet.population],
        ["Diameter",       "#{@planet.diameter} km"],
        ["Rotation",       "#{@planet.rotation_period} hrs"],
        ["Orbital Period", "#{@planet.orbital_period} days"],
        ["Gravity",        @planet.gravity],
        ["Surface Water",  "#{@planet.surface_water}%"]
      ].each do |k, v| %>
        <div class="data-row">
          <span class="data-key"><%= k %></span>
          <span class="data-val"><%= v.presence || "—" %></span>
        </div>
      <% end %>
    </div>
  </div>

  <div class="col-md-6">
    <div class="detail-panel">
      <div class="panel-title">Known Residents — <%= @planet.people.count %> records</div>
      <% if @planet.people.any? %>
        <div class="d-flex flex-wrap gap-2 mt-1">
          <% @planet.people.order(:name).each do |person| %>
            <%= link_to person.name, person_path(person), class: "btn-terminal btn-terminal-sm" %>
          <% end %>
        </div>
      <% else %>
        <p style="color: var(--c-muted); font-family: var(--c-mono); font-size: 0.75rem;">NO RECORDS FOUND</p>
      <% end %>
    </div>
  </div>
</div>